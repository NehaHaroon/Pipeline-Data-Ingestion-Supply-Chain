# --- API ---
API_HOST=ingestion-api
API_PORT=8000
API_TOKEN=ee910d618e617c559f1ca41a3a48c3c7
LOCAL_API_HOST=localhost

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_IOT=supply_chain_inventory
KAFKA_GROUP_ID=supply_chain_group


# --- Storage (optional but good to define explicitly) ---
STORAGE_RAW=storage/raw
STORAGE_INGESTED=storage/ingested
STORAGE_QUARANTINE=storage/quarantine
STORAGE_CDC_LOG=storage/cdc_log
STORAGE_CHECKPOINTS=storage/checkpoints

# --- Logging ---
LOG_LEVEL=INFO

# --- Batch ---
BATCH_SIZE_DEFAULT=1000
MAX_RETRIES=3

# --- CDC ---
CDC_CHECKPOINT_INTERVAL=500
CDC_TOPIC=supply_chain.public.inventory_transactions
CDC_GROUP_ID=cdc-ingestion-group
INGESTION_API_URL=http://ingestion-api:8000

# --- Telemetry ---
TELEMETRY_HEARTBEAT_INTERVAL=5
TRANSFORMATION_KPI_LOG_PATH=storage/ingested/detail_logs/transformation_kpis.jsonl

# --- Iceberg storage ---
STORAGE_ICEBERG_WAREHOUSE=storage/iceberg_warehouse
STORAGE_ICEBERG_CATALOG_URI=sqlite:///storage/iceberg_catalog.db
ICEBERG_NAMESPACE_BRONZE=bronze
ICEBERG_NAMESPACE_SILVER=silver
ICEBERG_NAMESPACE_GOLD=gold

# --- Database (important if you connect to Postgres later) ---
DB_TYPE=postgres
DATABASE_URL=postgresql://etl_user:etl_password@postgres:5432/supply_chain_db

